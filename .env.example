# Get telegram details
STORAGE_GROUP_ID=
ADMIN_ID=
# Telegram supergroups and channels have negative IDs internally. The 3843778132 you had is just the bare numeric part — the full API-compatible ID always has a -100 prefix, making it -1003843778132. Without the prefix, Telethon interprets it as a regular user ID (PeerUser) and fails to resolve it.

